# syntax=docker/dockerfile:1
FROM ghcr.io/cross-rs/aarch64-unknown-linux-musl:main AS toolchain

FROM ubuntu:24.04
ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
    ca-certificates \
    cmake \
    libclang-dev \
    qemu-user-static \
    && rm -rf /var/lib/apt/lists/*

COPY --from=toolchain /usr/local/aarch64-linux-musl/ /usr/local/aarch64-linux-musl/
COPY --from=toolchain /qemu-runner /qemu-runner
COPY --from=toolchain /base-runner.sh /base-runner.sh
COPY --from=toolchain /opt/toolchain.cmake /opt/toolchain.cmake
COPY --from=toolchain /usr/bin/aarch64-linux-musl-gcc.sh /usr/bin/aarch64-linux-musl-gcc.sh

ENV CROSS_TOOLCHAIN_PREFIX=aarch64-linux-musl- \
    CROSS_SYSROOT=/usr/local/aarch64-linux-musl \
    CROSS_TARGET_RUNNER="/qemu-runner aarch64" \
    CARGO_TARGET_AARCH64_UNKNOWN_LINUX_MUSL_LINKER=aarch64-linux-musl-gcc.sh \
    CARGO_TARGET_AARCH64_UNKNOWN_LINUX_MUSL_RUNNER="/qemu-runner aarch64" \
    AR_aarch64_unknown_linux_musl=aarch64-linux-musl-ar \
    CC_aarch64_unknown_linux_musl=aarch64-linux-musl-gcc \
    CXX_aarch64_unknown_linux_musl=aarch64-linux-musl-g++ \
    CMAKE_TOOLCHAIN_FILE_aarch64_unknown_linux_musl=/opt/toolchain.cmake \
    BINDGEN_EXTRA_CLANG_ARGS_aarch64_unknown_linux_musl="--sysroot=/usr/local/aarch64-linux-musl" \
    QEMU_LD_PREFIX=/usr/local/aarch64-linux-musl \
    RUST_TEST_THREADS=1 \
    CROSS_CMAKE_SYSTEM_NAME=Linux \
    CROSS_CMAKE_SYSTEM_PROCESSOR=aarch64 \
    CROSS_CMAKE_CRT=musl \
    CROSS_CMAKE_OBJECT_FLAGS="-ffunction-sections -fdata-sections -fPIC" \
    CROSS_BUILTINS_PATCHED_MINOR_VERSION=48

CMD ["/bin/bash"]
